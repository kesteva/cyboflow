{
  "name": "main",
  "version": "0.1.7",
  "description": "Electron main process for Claude Code Commander",
  "main": "dist/main/src/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsc -w",
    "build": "rimraf dist && tsc && npm run copy:assets && node scripts/mark-hooks-executable.js",
    "copy:assets": "mkdirp dist/main/src/database/migrations dist/main/src/orchestrator/workflows && cp src/database/*.sql dist/main/src/database/ && cp src/database/migrations/*.sql dist/main/src/database/migrations/ && node scripts/copy-workflow-assets.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.141",
    "@aptabase/electron": "^0.3.1",
    "@homebridge/node-pty-prebuilt-multiarch": "^0.12.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@sentry/electron": "^7.13.0",
    "@trpc/client": ">=11.0.0 <12.0.0",
    "@trpc/server": ">=11.0.0 <12.0.0",
    "better-sqlite3": "^11.7.0",
    "glob": "^11.0.0",
    "p-queue": "^7.4.1",
    "superjson": "^2.2.1",
    "trpc-electron": "0.1.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/glob": "^9.0.0",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "@vitest/coverage-v8": "^2.1.8",
    "electron": "^37.6.0",
    "eslint": "^9.17.0",
    "mkdirp": "^3.0.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
